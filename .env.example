# Database (Prisma) — PostgreSQL in production (Vercel Postgres Neon)
# Local dev: use a Postgres URL or a free Neon/Supabase dev database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Email (Resend) — password reset & email OTP; https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Verified sender domain in Resend (e.g. noreply@mail.yourdomain.com)
EMAIL_FROM="The Fix Collective <noreply@yourdomain.com>"

# SMS (Twilio) — SMS 2FA & phone verification — https://console.twilio.com
# Set Account SID + Auth Token, then either a sender number OR a Messaging Service (recommended for US A2P).
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_FROM_NUMBER="+1..."
# TWILIO_MESSAGING_SERVICE_SID="MG..."   # optional; use instead of TWILIO_FROM_NUMBER
#
# Local dev: without these, SMS is skipped and the OTP is printed in the terminal (only when NODE_ENV=development and not on Vercel).
# Trial: add each destination number under Phone Numbers → Verified Caller IDs or texts will not arrive; check Monitor → Logs → Messaging if API returns "queued" but you see nothing.

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Geocoding (Nominatim / OpenStreetMap) — identify your app in the User-Agent (see OSM usage policy)
# GEOCODE_USER_AGENT="TheFixCollective/1.0 (https://yoursite.com; contact@yoursite.com)"

# RootSync (OpenAI) — https://platform.openai.com/api-keys
# After changing this locally, restart `npm run dev` (Next reads env at process start).
# On Vercel: add OPENAI_API_KEY under Project → Settings → Environment Variables, then redeploy.
OPENAI_API_KEY="sk-..."
# Optional; default is gpt-4o-mini
# OPENAI_MODEL="gpt-4o-mini"

# Optional: show raw Prisma errors on signup API (Vercel env; remove after debugging)
# SIGNUP_DEBUG_ERRORS=1

# Vercel Blob — required for vendor listing image uploads on Vercel (serverless has no writable disk).
# Vercel dashboard → Storage → Blob → create store → connect project (injects BLOB_READ_WRITE_TOKEN).
# Local dev: omit to use public/uploads/vendor-listings/ on disk instead.
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."
