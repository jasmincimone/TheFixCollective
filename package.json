{
  "name": "the-fix-collective",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "WATCHPACK_POLLING=true next dev --port 3000",
    "dev:3001": "WATCHPACK_POLLING=true next dev --port 3001",
    "build": "NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "build:vercel": "prisma migrate deploy && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:set-user-role": "node scripts/set-user-role.mjs",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.3.2",
    "clsx": "^2.1.1",
    "encoding": "^0.1.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "openai": "^4.104.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1",
    "resend": "^4.8.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0"
  }
}
